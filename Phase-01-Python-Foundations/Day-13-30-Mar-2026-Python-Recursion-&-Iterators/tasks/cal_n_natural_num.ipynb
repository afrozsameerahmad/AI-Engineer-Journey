   "source": [
    "''' \n",
    "Write a recursive function to calculate the sum of first n natural numbers.\n",
    "'''\n",
    "\n",
    "def cal_sum(n):\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    return cal_sum(n - 1) + n\n",
    "\n",
    "result = cal_sum(5)\n",
    "print(result)"
   ]
