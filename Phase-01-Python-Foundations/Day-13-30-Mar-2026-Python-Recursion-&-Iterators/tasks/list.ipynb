   "source": [
    "''' \n",
    "Write a recursive function to print all elements of a list. \n",
    "Hint: use list & index as parameters.\n",
    "\n",
    " \n",
    "\n",
    "'''\n",
    "def print_list(lst, index=0):\n",
    "    if(index == len(lst)):\n",
    "        return\n",
    "    print(lst[index])\n",
    "    print_list(lst, index+1)\n",
    "print_list([1, 2, 3, 4, 5])"
   ]
  },
