   "source": [
    "''' \n",
    "Print factors / divisors of a number\n",
    "Factors of 12 are 1,2,3,4,6,12\n",
    "Factors of 15 are 1,3,5,15\n",
    "'''\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "85d2f559",
   "metadata": {},
   "outputs": [],
   "source": [
    "n= 20 \n",
    "num = n\n",
    "result=[]\n",
    "for i in range(1,num+1):\n",
    "    if num % i ==0:\n",
    "        result.append(i)\n",
    "print(result)\n",
    "    "
   ]
