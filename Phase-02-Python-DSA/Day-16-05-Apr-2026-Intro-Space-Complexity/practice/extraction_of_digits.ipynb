    "n=5873\n",
    "total=0\n",
    "while n>0:\n",
    "    last_digit=n%10\n",
    "    total +=last_digit\n",
    "    n //=10\n",
    "    \n",
    "print(total)\n",
    "#time complexity is O(logn) and space complexity is O(1)"
   ]
  }
