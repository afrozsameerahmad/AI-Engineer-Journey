    "''' \n",
    "Check Palindrome\n",
    "\n",
    "'''\n",
    "\n",
    "n= 1234\n",
    "num = n\n",
    "result=0\n",
    "while num>0:\n",
    "    td = num%10\n",
    "    result = (result*10) + ld\n",
    "    num //=10\n",
    "    \n",
    "print('palindrom' if num == result else 'not palindrome')\n",
    "# time complexity  is O(logn)\n",
    "#space complexity O(1)"
