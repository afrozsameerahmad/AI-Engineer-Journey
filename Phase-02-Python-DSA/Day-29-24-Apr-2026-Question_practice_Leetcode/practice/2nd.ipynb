   "source": [
    "nums=[2,4,6,7,9,11,18,19]\n",
    "target=6\n",
    "low=0\n",
    "high=len(nums)-1\n",
    "while low<=high:\n",
    "    mid = low+(high-low)//2\n",
    "    if nums[mid]==target:\n",
    "        print(mid)\n",
    "        break\n",
    "    elif nums[mid]<target:\n",
    "        low = mid + 1\n",
    "        \n",
    "    else:\n",
    "        high = mid - 1\n",
    "        \n",
    "    \n",
    "\n"
   ]
