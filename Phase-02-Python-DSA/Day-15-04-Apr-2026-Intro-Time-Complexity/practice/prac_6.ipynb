   "source": [
    "l=[1, 2, 3, 4, 5]\n",
    "for i in range(0,len(l)//2):\n",
    "    other = len(l)-i-1\n",
    "    temp = l[i]\n",
    "    l[i] = l[other]\n",
    "    l[other] = temp\n",
    "print(l)"
   ]
  },
