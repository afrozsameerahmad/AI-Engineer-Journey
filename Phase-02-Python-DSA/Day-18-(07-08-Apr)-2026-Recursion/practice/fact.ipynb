   "source": [
    "''' \n",
    "Find the factorial of a number using recursion\n",
    "'''"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "67d5464e",
   "metadata": {},
   "outputs": [
    {
