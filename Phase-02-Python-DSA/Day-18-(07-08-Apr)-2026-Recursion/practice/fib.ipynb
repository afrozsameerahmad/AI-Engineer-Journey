   "source": [
    "''' Fibonacci sequence '''\n",
    "\n",
    "def fib(n):\n",
    "    if n <= 1:\n",
    "        return n\n",
    "    \n",
    "    a, b = 0, 1\n",
    "    for _ in range(2, n+1):\n",
    "        a, b = b, a + b\n",
    "    \n",
    "    return b\n",
    "\n",
    "print(fib(6))\n",
    "# time complexity: O(n)\n",
    "# space complexity: O(1)"
   ]
  },
