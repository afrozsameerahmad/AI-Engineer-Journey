     ]
    }
   ],
   "source": [
    "nums =[1,2,3,4,5,7,9,11,11,12,34,34,56,56,56]\n",
    "n=len(nums)\n",
    "freq_map={}\n",
    "for i in range(0,n):\n",
    "    freq_map[nums[i]]=0\n",
    "j=0\n",
    "for k in freq_map:\n",
    "    nums[j]=k\n",
    "    j+=1\n",
    "    \n",
    "print(j)\n",
    "\n"
   ]
