   "source": [
    "nums = [ 23, 45, 12, 78, 56, 89 ]\n",
    "temp = nums[-1]\n",
    "for i in range(len(nums)-1,0,-1):\n",
    "    nums[i] = nums[i-1]\n",
    "nums[0] = temp\n",
    "print(nums)"
