   "id": "71aa852b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 21, 2, 3, 4, 5, 6, 7, 8, 9]\n"
     ]
    }
   ],
   "source": [
    "nums = [1,21,2,2,3,4,4,5,6,7,8,8,9]\n",
    "n=len(nums)\n",
    "freq_map={}\n",
    "for i in  range(0,n):\n",
    "    freq_map[nums[i]]=0\n",
    "j=0\n",
    "for k in freq_map:\n",
    "    nums[j]=k\n",
    "    j+=1\n",
    "print(nums[:j])\n",
    "\n",
    "    "
   ]
  },
